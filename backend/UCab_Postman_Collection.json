{
  "info": {
    "name": "UCab API Collection",
    "description": "Complete API collection for UCab cab booking system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "driverToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "rideId",
      "value": ""
    },
    {
      "key": "paymentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice User\",\n  \"email\": \"alice@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"password123\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Register Driver",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Driver\",\n  \"email\": \"bob@example.com\",\n  \"phone\": \"9876543211\",\n  \"password\": \"password123\",\n  \"role\": \"driver\",\n  \"licenseNumber\": \"DL1234567890\",\n  \"vehicleType\": \"sedan\",\n  \"vehicleNumber\": \"KA01AB1234\",\n  \"vehicleModel\": \"Toyota Camry\",\n  \"vehicleColor\": \"Black\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Updated\",\n  \"phone\": \"9876543210\",\n  \"address\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"Bangalore\",\n    \"state\": \"Karnataka\",\n    \"zipCode\": \"560001\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Drivers",
      "item": [
        {
          "name": "Get Nearby Drivers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/drivers/nearby?longitude=77.5946&latitude=12.9716&vehicleType=sedan",
              "host": ["{{baseUrl}}"],
              "path": ["drivers", "nearby"],
              "query": [
                {
                  "key": "longitude",
                  "value": "77.5946"
                },
                {
                  "key": "latitude",
                  "value": "12.9716"
                },
                {
                  "key": "vehicleType",
                  "value": "sedan"
                }
              ]
            }
          }
        },
        {
          "name": "Update Driver Location",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{driverToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"longitude\": 77.5946,\n  \"latitude\": 12.9716,\n  \"address\": \"MG Road, Bangalore\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/drivers/location",
              "host": ["{{baseUrl}}"],
              "path": ["drivers", "location"]
            }
          }
        },
        {
          "name": "Toggle Availability",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{driverToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/drivers/availability",
              "host": ["{{baseUrl}}"],
              "path": ["drivers", "availability"]
            }
          }
        },
        {
          "name": "Get Driver Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{driverToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/drivers/profile",
              "host": ["{{baseUrl}}"],
              "path": ["drivers", "profile"]
            }
          }
        },
        {
          "name": "Get Driver Earnings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{driverToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/drivers/earnings",
              "host": ["{{baseUrl}}"],
              "path": ["drivers", "earnings"]
            }
          }
        }
      ]
    },
    {
      "name": "Rides",
      "item": [
        {
          "name": "Get Fare Estimate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupLocation\": {\n    \"coordinates\": [77.5946, 12.9716],\n    \"address\": \"MG Road, Bangalore\"\n  },\n  \"dropLocation\": {\n    \"coordinates\": [77.6408, 12.9279],\n    \"address\": \"Whitefield, Bangalore\"\n  },\n  \"vehicleType\": \"sedan\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rides/estimate",
              "host": ["{{baseUrl}}"],
              "path": ["rides", "estimate"]
            }
          }
        },
        {
          "name": "Book Ride",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupLocation\": {\n    \"coordinates\": [77.5946, 12.9716],\n    \"address\": \"MG Road, Bangalore\"\n  },\n  \"dropLocation\": {\n    \"coordinates\": [77.6408, 12.9279],\n    \"address\": \"Whitefield, Bangalore\"\n  },\n  \"vehicleType\": \"sedan\",\n  \"paymentMethod\": \"cash\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rides",
              "host": ["{{baseUrl}}"],
              "path": ["rides"]
            }
          }
        },
        {
          "name": "Accept Ride",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{driverToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rides/{{rideId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["rides", "{{rideId}}", "accept"]
            }
          }
        },
        {
          "name": "Start Ride",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{driverToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rides/{{rideId}}/start",
              "host": ["{{baseUrl}}"],
              "path": ["rides", "{{rideId}}", "start"]
            }
          }
        },
        {
          "name": "Complete Ride",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{driverToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rides/{{rideId}}/complete",
              "host": ["{{baseUrl}}"],
              "path": ["rides", "{{rideId}}", "complete"]
            }
          }
        },
        {
          "name": "Rate Ride",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Excellent service!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rides/{{rideId}}/rate",
              "host": ["{{baseUrl}}"],
              "path": ["rides", "{{rideId}}", "rate"]
            }
          }
        },
        {
          "name": "Get My Rides",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rides/my-rides",
              "host": ["{{baseUrl}}"],
              "path": ["rides", "my-rides"]
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Process Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rideId\": \"{{rideId}}\",\n  \"paymentMethod\": \"card\",\n  \"cardDetails\": {\n    \"last4Digits\": \"1234\",\n    \"cardType\": \"visa\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": ["{{baseUrl}}"],
              "path": ["payments"]
            }
          }
        },
        {
          "name": "Get Payment Receipt",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments/{{paymentId}}/receipt",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "{{paymentId}}", "receipt"]
            }
          }
        },
        {
          "name": "Get My Payments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments/my-payments",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "my-payments"]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    }
  ]
}
